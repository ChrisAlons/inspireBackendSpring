      "name": "01 - Crear Paciente (happy path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const body = pm.response.json();",
              "    pm.collectionVariables.set('pacienteId', body.id);",
              "    console.log('pacienteId guardado:', body.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"tipoDocumentoCodigo\": \"DNI\",\n  \"numeroDocumento\": \"12345678\",\n  \"nombres\": \"Juan Carlos\",\n  \"apellidoPaterno\": \"García\",\n  \"apellidoMaterno\": \"López\",\n  \"fechaNacimiento\": \"1990-05-15\",\n  \"sexoCodigo\": \"M\",\n  \"celular\": \"987654321\",\n  \"email\": \"juan.garcia@example.com\",\n  \"direccion\": \"Av. Lima 123, Miraflores\",\n  \"lugarNacimiento\": \"Lima\",\n  \"procedencia\": \"Lima\",\n  \"viajesUltimoAnio\": \"Viajó a Cusco en enero\",\n  \"gradoInstruccionCodigo\": \"SUPERIOR\",\n  \"ocupacion\": \"Ingeniero de Sistemas\",\n  \"estadoCivilCodigo\": \"SOLTERO\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/pacientes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "pacientes"]
        }
      }
    },
